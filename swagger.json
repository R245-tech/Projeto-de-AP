      }
    },
    "schemas" : {
      "Playlist" : {
        "type" : "object",
        "required" : [ "name" ],
        "properties" : {
          "playlist_id" : {
            "type" : "string",
            "example" : "pl_550"
          },
          "name" : {
            "type" : "string",
            "example" : "Treino Pesado"
          },
          "description" : {
            "type" : "string",
            "example" : "Músicas para focar no ginásio."
          }
        },
        "xml" : {
          "name" : "playlist"
        }
      },
      "Musica" : {
        "type" : "object",
        "required" : [ "artist", "playtime", "title" ],
        "properties" : {
          "music_id" : {
            "type" : "integer",
            "format" : "int64",
            "example" : 10
          },
          "title" : {
            "type" : "string",
            "example" : "Bohemian Rhapsody"
          },
          "playtime" : {
            "type" : "string",
            "example" : "3:45"
          },
          "artist" : {
            "type" : "string",
            "example" : "Queen"
          },
          "genero" : {
            "type" : "string",
            "example" : "Rock"
          },
          "num_likes" : {
            "type" : "string",
            "example" : "100K"
          }
        },
        "xml" : {
          "name" : "musica"
        }
      },
      "User" : {
        "type" : "object",
        "required" : [ "username", "email" ],
        "properties" : {
          "user_id" : {
            "type" : "integer",
            "format" : "int64",
            "example" : 10
          },
          "username" : {
            "type" : "string",
            "example" : "theUser"
          },
          "email" : {
            "type" : "string",
            "format" : "email",
            "example" : "john@email.com"
          },
          "password" : {
            "type" : "string",
            "format" : "password",
            "example" : "12345"
          },
          "is_minor" : {
            "type" : "boolean",
            "example" : false
          }
        },
        "xml" : {
          "name" : "user"
        }
      },
      "Device" : {
        "type" : "object",
        "required" : [ "device_id" ],
        "properties" : {
          "device_id" : {
            "type" : "string",
            "example" : "phone_01"
          },
          "location" : {
            "type" : "string",
            "example" : "Lisboa, PT"
          },
          "notifications" : {
            "type" : "boolean",
            "example" : true
          }
        },
        "xml" : {
          "name" : "device"
        }
      },
      "Subscription" : {
        "type" : "object",
        "required" : [ "subscription_id", "plan_type" ],
        "properties" : {
          "subscription_id" : {
            "type" : "string",
            "example" : "sub_99"
          },
          "plan_type" : {
            "type" : "string",
            "enum" : [ "free", "individual", "family", "student" ],
            "example" : "family"
          },
          "status" : {
            "type" : "string",
            "example" : "active"
          }
        },
        "xml" : {
          "name" : "subscription"
        }
      },
      "Error" : {
        "type" : "object",
        "required" : [ "code", "message" ],
        "properties" : {
          "code" : {
            "type" : "string"
          },
          "message" : {
            "type" : "string",
            "example" : "O recurso solicitado não existe."
          }
        }
      }
    }

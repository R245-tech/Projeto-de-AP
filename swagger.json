openapi: 3.0.0
info:
  title: Spotify Mockup API
  description: API for managing music, playlists, and user subscriptions.
  version: 3.0.0

servers:
  # Added by API Auto Mocking Plugin
  - description: SwaggerHub API Auto Mocking
    url: https://virtserver.swaggerhub.com/faculdadedeciencia/Rikina/1.0.0
  - url: https://api.spotify-mockup.io/v1
    description: Main Production Server

# the list of micro services concerned
tags:
  - name: "playlist services"
    description: "Responsible for all actions surrounding playlists, such as creating and editing metadata. Note: User-generated descriptions are scanned for compliance."
  - name: "user services"
    description: "Handles user accounts and personal data. Note: Personal data (email/phone) is encrypted and hidden for privacy."
  - name: "music services"
    description: "Stores songs and related data like genre and likes. Publicly accessible metadata."
  - name: "device management services"
    description: "Manages devices associated with a user. Private data: Device IDs and locations are only visible to the owner."
  - name: "subscription services"
    description: "Tracks subscription plans and billing. Sensitive: Contains financial tier information; restricted access."

# the specific actions we need our services to perform

paths: #

  # ### PLAYLIST SERVICES ###

  /playlist: #path to backend
    post: #type of action
      tags:
        - "playlist services" #the microservice responsible for this particular task
      summary: "Adicionar música a uma playlist" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: playlist_id
          in: path
          required: true
          schema: 
            type: string
        - name: music_id
          in: path
          required: true
          schema:
            type: string 
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Música adicionada com sucesso"
        '404':
          description: "Playlist ou Música não encontrada"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  /playlist/{playlist_id}: #path to backend
    put: #type of action
      tags:
        - "playlist services" #the microservice responsible for this particular task
      summary: "editar metadados(alterar o seu nome, descrição...)" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: playlist_id
          in: path
          required: true
          schema: #dafuc is this? the expected data type?
            type: string
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Playlist'

      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Playlist alterada com sucesso"


  /playlist/{playlist_id}/user/{user_id}: #path to backend
    put: #type of action
      tags:
        - "playlist services" #the microservice responsible for this particular task
      summary: "adicionar ouvinte" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: playlist_id
          in: path
          required: true
          schema: #the expected data type
            type: string
        - name: user_id
          in: path
          required: true
          schema: # the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Ouvinte adicionado com sucesso"

  /playlist/{playlist_id}/: #path to backend
    post: #type of action
      tags:
        - "playlist services" #the microservice responsible for this particular task
      summary: "criar playlist" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
      - name: playlist_id
        in: path
        required: true
        schema: #the expected data type
          type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Ouvinte adicionado com sucesso"


    delete: #type of action
      tags:
        - "playlist services" #the microservice responsible for this particular task
      summary: "apagar playlist" #description of task
      parameters:
      - name: playlist_id
        in: path
        required: true
        schema:
          type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Playlist apagada com sucesso"

  # ### USER SERVICES ###

  /user/: #path to backend
    post: #type of action
      tags:
        - "user services" #the microservice responsible for this particular task
      summary: "criar novo user" #description of task
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Nova conta criada com sucesso"

  /user/{user_id}/profile: #path to backend
    put: #type of action
      tags:
        - "user services" #the microservice responsible for this particular task
      summary: "editar informações do perfil" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: user_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Perfil editado com sucesso"

  /user/{user_id}/friend/: #path to backend ## SHOULDN'T THE SECOND {user_id} be {friend_id}? Se esse fôr o caso, esta não tem de ser uma acção POST?
    post: #type of action
      tags:
        - "user services" #the microservice responsible for this particular task
      summary: "adicionar amigo" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: user_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Novo amigo adicionado com sucesso"

  /user/{user_id}: #path to backend
    delete: #type of action
      tags:
        - "user services" #the microservice responsible for this particular task
      summary: "apagar conta" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: user_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Conta apagada"

  /user/{user_id}/restriction: #path to backend
    put: #type of action
      tags:
        - "user services" #the microservice responsible for this particular task
      summary: "editar controlo de conteúdo para menores de idade" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: user_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Conteúdo restringido"

  /user/{user_id}/friend/{friend_id}/block: #path to backend
    put: #type of action
      tags:
        - "user services" #the microservice responsible for this particular task
      summary: "bloquear user" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: user_id
          in: path
          required: true
          schema: #the expected data type
            type: string
        - name: friend_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "User bloqueado. Lamentamos que tenhas tido esta experiência."

  # ### MUSIC SERVICES ### 

  /music: #path to backend
    post: #type of action
      tags:
        - "music services" #the microservice responsible for this particular task
      summary: "publicar música" #description of task
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Música publicada."

  /music/{music_id}/ratings: #path to backend
    get: #type of action
      tags:
        - "music services" #the microservice responsible for this particular task
      summary: "verificar ratings" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: music_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Retornar ratings da música."

  /music/{music_id}/genero: #path to backend
    put: #type of action
      tags:
        - "music services" #the microservice responsible for this particular task
      summary: "alterar género musical. Privado, exclusivo para o autor da música" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: music_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Género musical alterado."

  /music/{music_id}/{author_id}: #path to backend
    get: #type of action
      tags:
        - "music services" #the microservice responsible for this particular task
      summary: "ver autor" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: music_id
          in: path
          required: true
          schema: #the expected data type
            type: string
        - name: author_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Retornar autor"

  /music/{music_id}/{playlist_id}: #path to backend
    get: #type of action
      tags:
        - "music services" #the microservice responsible for this particular task
      summary: "verificar a que album pertence a musica" #description of task
      parameters: # every {whatever} in the path, that is: the items necessary for the action
        - name: music_id
          in: path
          required: true
          schema: #the expected data type
            type: string
        - name: playlist_id
          in: path
          required: true
          schema: #the expected data type
            type: string
      responses: # the reactions we're expecting after performing these actions.
        '200': # if everything went well, execute the following
          description: "Retornar album"

  # ### DEVICE MANAGEMENT SERVICES ###

  /device/register:
    post:
      tags: ["device management services"]
      summary: "registar dispositivo"
      responses:
        '200':
          description: "Dispositivo registado com sucesso."

  /device/{device_id}: # <--- This is the ONLY time this line should appear
    get:
      tags: ["device management services"]
      summary: "ver dispositivos associados à conta."
      parameters:
        - name: device_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "Retornar dispositivos associados."
    put: # <--- Notice how PUT is inside the same {device_id} block
      tags: ["device management services"]
      summary: "editar notificações ou localização"
      parameters:
        - name: device_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "Configurações do dispositivo alteradas."
    delete: # <--- DELETE is also inside here
      tags: ["device management services"]
      summary: "remover o dispositivo"
      parameters:
        - name: device_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "Dispositivo removido com sucesso."

  # ### SUBSCRIPTION SERVICES ###

  /subscription/{subscription_id}:
    get:
      tags: ["subscription services"]
      summary: "verificar tipo de subscrição."
      parameters:
        - name: subscription_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "Retornar tipo de subscrição."

  /subscription/{subscription_id}/pause:
    put:
      tags: ["subscription services"]
      summary: "pôr em pausa subscrição."
      parameters:
        - name: subscription_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "Subscrição pausada."

  /subscription/{subscription_id}/plan:
    put:
      tags: ["subscription services"]
      summary: "mudar plano de subscrição."
      parameters:
        - name: subscription_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "Plano alterado."

  /subscription/{subscription_id}/family:
    get:
      tags: ["subscription services"]
      summary: "ver membros do agregado."
      parameters:
        - name: subscription_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "Retornar membros."

  /subscription/{subscription_id}/history:
    get:
      tags: ["subscription services"]
      summary: "ver histórico da subscrição."
      parameters:
        - name: subscription_id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: "sucesso"
        '400': 
          $ref: "#/components/responses/BadRequest"
        '403':
          $ref: "#/components/responses/ForbiddenError"
        '408':
          $ref: "#/components/responses/TimeoutError"
      xml:
        name: subscription

components:
  securitySchemes:
    bearerAuth:            
      type: http
      scheme: bearer
      bearerFormat: JWT

  schemas: 
    Playlist:
      type: object
      required:
        - name
      properties:
        playlist_id: 
          type: string
          example: "pl_550"
        name:
          type: string
          example: "Treino Pesado"
        description:
          type: string
          example: "Músicas para focar no ginásio."
      xml:
        name: playlist
    # --- MUSIC SERVICES ---
    Musica:
      type: object
      required:
        - artist
        - playtime
        - title
      properties:
        music_id:
          type: integer
          format: int64
          example: 10
        title:
          type: string
          example: "Bohemian Rhapsody"
        playtime:
          type: string
          example: "3:45"
        artist:
          type: string
          example: "Queen"
        genero:
          type: string
          example: "Rock"
        num_likes:
          type: string
          example: "100K"
      xml:
        name: musica

    # --- USER SERVICES ---
    User:
      type: object
      required:
        - username
        - email
        - password
      properties:
        user_id:
          type: integer
          format: int64
          example: 10
        username:
          type: string
          example: "theUser"
        email:
          type: string
          format: email
          example: "john@email.com"
        password:
          type: string
          format: password
          example: "12345"
        is_minor:
          type: boolean
          example: false
      xml:
        name: user

    # --- DEVICE MANAGEMENT ---
    Device:
      type: object
      required:
        - device_id
      properties:
        device_id:
          type: string
          example: "phone_01"
        location:
          type: string
          example: "Lisboa, PT"
        notifications:
          type: boolean
          example: true
      xml:
        name: device

    # --- SUBSCRIPTION SERVICES ---
    Subscription:
      type: object
      required:
        - subscription_id
        - plan_type
      properties:
        subscription_id:
          type: string
          example: "sub_99"
        plan_type:
          type: string
          enum: [free, individual, family, student]
          example: "family"
        status:
          type: string
          example: "active"
      xml:
        name: subscription
    

    Error: 
      type: "object"
      required: 
        - code 
        - message
      
      properties: 
        code: 
          type: integer
          example: 400
          
      message: 
        type: string
        example: "Pedido inválido. Verifique os campos enviados."
        
      details: 
        type: string
        example: "O campo 'email' não é um endereço válido."
      xml:
        name: Error

  responses: 
      BadRequest: 
        description: "Erro de validação nos dados enviados."
        content: 
          application/json:  
              schema:  
                $ref: "#/components/schemas/Error"
          
        
      ForbiddenError: 
          description: "O utilizador não tem permissão para esta ação."
            content: 
              application/json: 
              schema:
                "$ref": "#/components/schemas/Error"
          
        
        TimeoutError: 
          description: "O servidor demorou demasiado tempo a responder."
            content: 
              application/json: 
                schema: 
                  "$ref": "#/components/schemas/Error" 

security:
  - bearerAuth: []
